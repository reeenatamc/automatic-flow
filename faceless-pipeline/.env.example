# Subtítulos automáticos desde el audio (Whisper en la nube).
# Copia este archivo a  .env  y pega tu key. La IA corre en la nube, NO en tu Mac.

# Opción recomendada — Groq (gratis): saca tu key en https://console.groq.com/keys
GROQ_API_KEY=

# Alternativa — OpenAI (de pago, ~$0.006/min): https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# (opcional) forzar modelo: whisper-large-v3-turbo (Groq) | whisper-large-v3 | whisper-1 (OpenAI)
# WHISPER_MODEL=whisper-large-v3-turbo
